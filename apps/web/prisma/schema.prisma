generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- SIWS (Sign-In with Solana) -------------------------------------------

model AuthNonce {
  nonce     String    @id
  domain    String
  // The full SolanaSignInInput this server issued, as JSON. On verify the
  // signature is checked against THIS canonical input, not the client's echoed
  // copy, so no non-domain field (uri/issuedAt/expirationTime/...) can be
  // tampered with (Audit-1 TOB-07). Nullable for backward compatibility with
  // any pre-migration rows; verify rejects a nonce that lacks it.
  issuedInput String?
  // Client IP that requested this nonce, for per-IP rate limiting (Audit-1
  // TOB-06). Nullable: not always resolvable behind proxies. Short-lived —
  // purged with the nonce once expired.
  ip        String?
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([expiresAt])
  @@index([ip, createdAt])
}

// --- Subscriptions (PAUSED — Stripe checkout/webhook not yet built) -------
// See CLAUDE.md "PAUSED: subscription / premium tier". This model exists so
// the schema is ready, but is currently unpopulated.

model Subscription {
  walletAddress        String    @id
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?   @unique
  status               String    @default("inactive") // "active" | "past_due" | "canceled" | "inactive"
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

// --- Deployment index (dashboard / resumability) ---------------------------

model Deployment {
  mintAddress       String    @id
  walletAddress     String
  decimals          Int
  hasMetadata       Boolean   @default(false)
  metadataAttached  Boolean   @default(false)
  name              String?
  symbol            String?
  uri               String?
  signature         String
  metadataSignature String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // --- Curation / review (for the "Created on Smeltr" explorer) ------------
  // Every mint indexed here is a review candidate. The founder reviews the
  // weekly stream and sets reviewStatus; only "approved"/"featured" ever
  // surface in the public /created explorer (curated, opt-in showcase — never
  // an open feed). See corporate/market-expansion-roadmap.md.
  reviewStatus      String    @default("pending") // pending | approved | rejected | featured | hidden
  reviewedAt        DateTime?
  reviewNote        String?

  @@index([walletAddress])
  @@index([reviewStatus, createdAt])
}

// --- Platform-funded upload quotas (Audit-1 TOB-04) ------------------------
// Per-wallet, per-UTC-day usage counters for the platform-funded Irys upload
// endpoint. Prevents a single premium (or forged) session from draining the
// platform storage balance via repeated large uploads (financial DoS).
// One row per (wallet, day); rows are cheap and can be pruned by a later job.

model UploadUsage {
  walletAddress String
  day           String   // UTC calendar day, "YYYY-MM-DD"
  requests      Int      @default(0)
  bytes         BigInt   @default(0)
  updatedAt     DateTime @updatedAt

  @@id([walletAddress, day])
}
