{
  "name": "token-deployment-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:apps",
    "build:apps": "cd apps/web && npm run build",
    "dev": "cd apps/web && npm run dev",
    "test": "npm run test:registry && npm run test:web && npm run test:mcp",
    "test:ci": "npm run test:registry:unit && npm run test:web:ci && npm run test:mcp",
    "test:registry": "cd packages/tx-builder && npm test",
    "test:registry:unit": "cd packages/tx-builder && npm run test:unit",
    "test:web": "cd apps/web && npm test",
    "test:web:ci": "cd apps/web && npm run test:ci",
    "test:mcp": "cd packages/mcp-server && npm run test:unit",
    "test:a2:unit": "cd packages/tx-builder && npm run test:unit -- --testPathPattern=\"legacySplAdapter|deploymentTarget|metaplexMetadata\"",
    "test:a2:integration": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/run-integration.ps1",
    "test:a3:unit": "cd packages/mcp-server && npm run test:unit -- --testPathPattern=tools",
    "validator:local": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start-local-validator.ps1",
    "validator:local:wsl": "wsl -e bash -lc \"rm -rf ~/smeltr-localnet-ledger && exec solana-test-validator --reset --ledger ~/smeltr-localnet-ledger --clone-upgradeable-program metaqbxxUerdq28cj1RbAWkYQm3ybzjb6a8bt518x1s --url https://api.mainnet-beta.solana.com\"",
    "validator:stop:wsl": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-local-validator-wsl.ps1",
    "validator:clean": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/clean-local-validator.ps1",
    "test:a2:integration:devnet": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/test-integration-devnet.ps1",
    "smoke:mainnet": "powershell -NoProfile -ExecutionPolicy Bypass -File run-mainnet-smoke-test.ps1",
    "beta:verify": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/verify-beta-readiness.ps1"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
