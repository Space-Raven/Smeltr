{
  "name": "token-deployment-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "react": "$react",
    "react-dom": "$react-dom"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:apps",
    "build:apps": "cd apps/web && npm run build",
    "dev": "cd apps/web && npm run dev",
    "test": "npm run test:registry && npm run test:web && npm run test:mcp",
    "test:ci": "npm run test:registry:unit && npm run test:web:ci && npm run test:mcp",
    "test:registry": "cd packages/tx-builder && npm test",
    "test:registry:unit": "cd packages/tx-builder && npm run test:unit",
    "test:web": "cd apps/web && npm test",
    "test:web:ci": "cd apps/web && npm run test:ci",
    "test:mcp": "cd packages/mcp-server && npm run test:unit"
  },
  "dependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0"
  }
}
