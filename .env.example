# --- Database (Prisma) -------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/platform"

# --- SIWS / session -----------------------------------------------------------
# Domain shown in the Sign-In with Solana message. Must match the deployed
# host exactly (checked in /api/auth/verify against the issued nonce record).
NEXT_PUBLIC_APP_DOMAIN="smeltr.org"

# Secret used to sign session JWTs (apps/web/lib/session.ts). Generate with:
#   openssl rand -base64 32
SESSION_JWT_SECRET="replace-me-with-a-random-secret"

# --- Solana RPC ----------------------------------------------------------------
# Production: use Helius/QuickNode mainnet URL — NOT api.mainnet-beta.solana.com
# (rate-limits getBalance/confirmTransaction). Build fails on Vercel production
# if missing or public. See docs/BETA_LAUNCH_CHECKLIST.md
NEXT_PUBLIC_SOLANA_RPC_URL="https://api.devnet.solana.com"

# --- Platform protocol fee (apps/web/lib/constants.ts) -----------------------
# Recipient wallet for the per-mint protocol fee (0.03 SOL, captured in
# transaction 1 and shown transparently in the review step). Leave UNSET to
# disable fee capture (e.g. local dev). This is a payment destination, not a
# token authority, so it is exempt from the authority denylist below.
# NEXT_PUBLIC_PLATFORM_FEE_RECIPIENT=<base58 pubkey>

# --- Platform authority denylist (packages/module-registry/src/schema.ts) ---
# Comma/whitespace-separated base58 pubkeys of every platform-controlled wallet.
# MUST be NEXT_PUBLIC_ — inlined into the client bundle at BUILD time (TOB-01).
# After changing this in Vercel you must trigger a new deployment (not just save).
# Do not wrap the value in quotes in the Vercel UI.
# NEXT_PUBLIC_PLATFORM_AUTHORITY_DENYLIST=<pubkey1>,<pubkey2>

# --- Irys / Arweave metadata uploads (apps/web/hooks/useIrysUpload.ts) -------
# Arweave gateway URL (default shown; currently no env var needed, built-in)
# IRYS_GATEWAY_URL="https://gateway.irys.xyz"

# --- Stripe (subscription / premium tier) ------------------------------------
# Beta default: Smeltr+ DISABLED until legal review + Stripe webhooks verified.
# Set BOTH to "true" together to enable purchases and premium features.
# SMELTR_PLUS_ENABLED="false"
# NEXT_PUBLIC_SMELTR_PLUS_ENABLED="false"
#
# STRIPE_SECRET_KEY=sk_live_...          # from Stripe dashboard → Developers → API keys
# STRIPE_WEBHOOK_SECRET=whsec_...        # from Stripe dashboard → Webhooks → signing secret
# STRIPE_PRICE_ID=price_...             # $19/mo recurring price ID (create in Stripe Products)
#
# --- Platform-funded Irys uploads (premium tier) -----------------------------
# Private key of the platform wallet that funds Irys storage for premium users.
# Base58-encoded 64-byte secret key (Solana keypair). Fund this wallet with SOL
# before enabling premium uploads. Keep this secret — never expose client-side.
# PLATFORM_IRYS_PRIVATE_KEY=<base58 secret key>
#
# --- Platform RPC (server-side) ------------------------------------------------
# Platform-owned RPC endpoint (e.g. Helius/QuickNode) — used by server-side ops
# (Irys uploads, the sweep cron). Keep the API key server-side.
# PLATFORM_RPC_URL="https://mainnet.helius-rpc.com/?api-key=YOUR_KEY"
#
# Expected cluster for hot-wallet ops (audit-2 M3). The sweeper refuses to run
# if the RPC URL's recognizable cluster differs. Defaults to mainnet in
# production; set "devnet" explicitly for a devnet ops environment.
# PLATFORM_SOLANA_CLUSTER="mainnet"
#
# --- Irys hot-wallet auto-sweep (Vercel Cron: /api/ops/sweep-irys) ------------
# Excess SOL in the hot Irys wallet is swept to the Founder wallet (the ONLY
# allowed destination) on a schedule, leaving a working reserve.
# Founder pubkey — sole sweep destination (public, also in the denylist):
# PLATFORM_FOUNDER_PUBKEY=<base58 pubkey>
# Shared secret Vercel Cron presents as `Authorization: Bearer <CRON_SECRET>`;
# gates the endpoint against public triggering. Generate a random 32+ byte value.
# CRON_SECRET=<random secret>
# SOL to keep in the Irys wallet for uploads between sweeps (default 0.5):
# IRYS_SWEEP_RESERVE_SOL=0.5
# Minimum excess SOL before a sweep runs, avoids dust transactions (default 0.05):
# IRYS_SWEEP_MIN_SOL=0.05

# --- Admin mint review (app/api/admin/*) -------------------------------------
# Base58 pubkey(s) allowed to access the mint-review console (/admin/review) and
# curate the "Created on Smeltr" explorer. Comma/space separated. Server-side
# only (never NEXT_PUBLIC_). Defaults to PLATFORM_FOUNDER_PUBKEY if unset.
# PLATFORM_ADMIN_PUBKEYS=<base58 pubkey>,<base58 pubkey>
