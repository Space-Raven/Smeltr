{
  "name": "@platform/tx-builder",
  "version": "0.1.0",
  "private": true,
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "test": "npm run test:unit",
    "test:all": "jest --detectOpenHandles",
    "test:unit": "jest --detectOpenHandles --testPathPattern=\"extensionCollision|platformAuthorityDenylist|moduleIntegrity|legacySplAdapter|deploymentTarget\"",
    "test:devnet": "jest --detectOpenHandles --runInBand --testPathPattern=\"metadata.devnet\"",
    "test:integration": "jest --detectOpenHandles --runInBand --testPathPattern=\"metadata.devnet|legacyMetaplex\""
  },
  "dependencies": {
    "@platform/module-registry": "*",
    "@solana/spl-token": "^0.4.0",
    "@solana/spl-token-metadata": "^0.1.0",
    "@solana/web3.js": "^1.95.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.4.0"
  }
}
